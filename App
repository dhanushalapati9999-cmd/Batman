                            return (
                                <button
                                    key={t.id}
                                    onClick={() => setTab(t.id)}
                                    style={{
                                        background: active ? `${col}10` : "transparent",
                                        border: "none",
                                        borderBottom: `2px solid ${active ? col : "transparent"}`,
                                        color: active ? col : C.textM,
                                        padding: "14px 16px",
                                        cursor: "pointer",
                                        fontFamily: "'JetBrains Mono', 'Courier New', monospace",
                                        fontSize: 10,
                                        letterSpacing: 3,
                                        transition: "all 0.2s",
                                        whiteSpace: "nowrap",
                                        flexShrink: 0,
                                        outline: "none",
                                    }}
                                    onMouseEnter={(e) => {
                                        if (!active)
                                            e.target.style.color = col;
                                    }}
                                    onMouseLeave={(e) => {
                                        if (!active)
                                            e.target.style.color = C.textM;
                                    }}
                                >
                                    <span style={{ marginRight: 6 }}>{t.icon}</span>
                                    {t.label}
                                </button>
                            );
                        })}
                    </nav>

                    {/* Content */}
                    <main style={{ flex: 1 }}>{views[tab]}</main>

                    {/* Footer */}
                    <footer
                        style={{
                            textAlign: "center",
                            padding: "16px",
                            borderTop: `1px solid ${C.border}`,
                            fontFamily: "'JetBrains Mono', 'Courier New', monospace",
                            fontSize: 7,
                            letterSpacing: 3,
                            color: C.textM,
                            flexShrink: 0,
                        }}
                    >
                        DAY {daysActive} &nbsp;|&nbsp; {fmt(TODAY).toUpperCase()} &nbsp;|&nbsp; STREAK:{" "}
                        {streak}D
                    </footer>
                </div>
            );
        }

        // ─── RENDER TO DOM ─────────────────────────────────────────────────────────
        ReactDOM.render(<BatmanTracker />, document.getElementById("root"));
    </script>
</body>
</html>
